# Production environment configuration
FLASK_DEBUG=false
PORT=5000
SECRET_KEY=change-this-in-production-with-a-secure-random-string

# Database
DATABASE=/data/studymind.db

# Ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_TIMEOUT=90

# Caching
CACHE_TTL_HOURS=24

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# Logging
LOG_LEVEL=INFO